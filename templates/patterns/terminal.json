{
  "$schema": "https://tuck.sh/schemas/patterns-v1.json",
  "category": "terminal",
  "patterns": [
    {
      "pattern": "~/.tmux.conf",
      "category": "terminal",
      "description": "Tmux configuration",
      "sensitive": false,
      "isDirectory": false,
      "exclude": []
    },
